{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!assets|icons|favicon\\.svg|manifest\\.webmanifest|sw\\.js|workbox-.*).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/jobs/import-google-sheet",
      "schedule": "0 0 * * *"
    }
  ]
}
